    },
    {
      "id": "viktor-respects-conventions",
      "agent": "viktor",
      "task": "src/util/parse-args.ts에 새 옵션 --json을 추가해줘",
      "expectedAnchors": ["검증 방법", "파일", "테스트"],
      "antiAnchors": ["새 라이브러리"]
    },
    {
      "id": "orianna-defines-empty-state",
      "agent": "orianna",
      "task": "검색 결과 화면의 UX 결정",
