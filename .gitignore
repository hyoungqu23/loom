# --- Node / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- TypeScript build output ---
# `dist/` is rebuilt by `npm run build`. The `bin/loom.js` shim requires
# `../dist/cli`, so consumers must build before running. If the project
# ever ships compiled artefacts to npm, drop this line and rely on
# `.npmignore` instead.
dist/
*.tsbuildinfo

# --- Loom runtime / per-workspace state ---
# This package itself acts as a workspace during dev; everything Loom
# writes at runtime is per-feature / per-run and should not be tracked.
.loom/
*.session.log

# --- Test / eval output ---
coverage/
.vitest-cache/
.nyc_output/
.eval-out/

# --- Local IDE / editor / OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.iml

# --- Claude Code local settings (per-machine permissions cache) ---
# `.claude/skills/` is the bundled skill set and should be tracked.
# Only the local settings file is per-machine.
.claude/settings.local.json
.claude/.session/

# --- Secrets ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets.json

# --- Misc generated ---
*.log
tmp/
.tmp/
